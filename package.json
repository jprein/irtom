		"audiosprite": "^0.7.2",
		"detectrtc": "^1.4.1",
		"gsap": "^3.14.2",
		"lodash": "^4.17.23",
		"recordrtc": "^5.6.2",
		"svgson": "^5.3.1",
		"toastify-js": "^1.12.0",
		"vite-plugin-svgo": "^2.0.0",
		"vite-plugin-svgr": "^4.5.0"
	}
